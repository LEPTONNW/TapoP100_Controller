<Window x:Class="TapoP100_Controller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tapo P100 Controller"
        Width="920"
        Height="789"
        MinWidth="820"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#EEF3F7">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#F9FBFC" />
        <SolidColorBrush x:Key="BorderBrush" Color="#D7E0E8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0E7490" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#155E75" />
        <SolidColorBrush x:Key="DangerBrush" Color="#BE123C" />
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#284354" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>
        <Style x:Key="PasswordStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
            <Setter Property="Margin" Value="0" />
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="28"
                Background="{StaticResource AccentDarkBrush}"
                CornerRadius="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Tapo P100 Controller"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#D8F3F8"
                               FontSize="14"
                               Text="IP 주소와 Tapo 계정 정보를 입력한 뒤 플러그 전원을 제어할 수 있는 독립형 WPF 화면입니다." />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="16,10"
                        Background="#1E8AA4"
                        CornerRadius="16"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="연결 상태"
                                   FontSize="12"
                                   Foreground="#D8F3F8" />
                        <TextBlock x:Name="ConnectionStatusTextBlock"
                                   Margin="0,4,0,0"
                                   Text="대기 중"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="24"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22">
                <StackPanel>
                    <TextBlock Text="연결 정보"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#193243" />
                    <TextBlock Margin="0,8,0,24"
                               Text="실제 제어 코드 연결 시 그대로 사용할 수 있도록 입력 컨트롤 이름을 미리 잡아두었습니다."
                               Foreground="#5E7484"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Tapo IP 주소" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="IpAddressTextBox"
                             Style="{StaticResource InputStyle}"
                             Text="192.168.0.125" />

                    <TextBlock Text="아이디" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="UsernameTextBox"
                             Style="{StaticResource InputStyle}"
                             Text="example@domain.com" />

                    <TextBlock Text="비밀번호" Style="{StaticResource FieldLabelStyle}" />
                    <PasswordBox x:Name="PasswordInput"
                                 Style="{StaticResource PasswordStyle}" />

                    <Border Margin="0,6,0,24"
                            Padding="14"
                            Background="#E6F7FB"
                            CornerRadius="14">
                        <TextBlock Text="현재 화면은 플러그 제어용 입력/버튼 UI입니다. 이후 ON/OFF 로직과 설정 저장 기능을 붙이기 쉽게 구성했습니다."
                                   Foreground="#28556A"
                                   TextWrapping="Wrap" />
                    </Border>

                    <UniformGrid Columns="2" Rows="1">
                        <Button x:Name="PlugOnButton"
                                Content="플러그 ON"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        <Button x:Name="PlugOffButton"
                                Content="플러그 OFF"
                                Style="{StaticResource DangerButtonStyle}" />
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="24"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="22">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="현재 대상"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#5E7484" />
                            <TextBlock x:Name="TargetIpPreviewTextBlock"
                                       Margin="0,8,0,0"
                                       Text="192.168.0.125"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#193243" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="최근 명령"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#5E7484" />
                            <TextBlock x:Name="LastCommandTextBlock"
                                       Margin="0,8,0,0"
                                       Text="없음"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#193243" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Padding="24"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="22">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0">
                            <TextBlock DockPanel.Dock="Left"
                                       Text="실행 로그"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#193243" />
                            <Button x:Name="ClearLogButton"
                                    DockPanel.Dock="Right"
                                    Width="96"
                                    Height="34"
                                    Margin="12,0,0,0"
                                    Content="로그 지우기"
                                    FontSize="13"
                                    Cursor="Hand" />
                        </DockPanel>

                        <TextBox Grid.Row="2"
                                 x:Name="LogTextBox"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 AcceptsReturn="True"
                                 Padding="14"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 Background="White"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 BorderThickness="1.2"
                                 Text="[로그가 여기에 표시됩니다]" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
